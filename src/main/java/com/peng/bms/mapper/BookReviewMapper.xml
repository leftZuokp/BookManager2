<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.peng.bms.mapper.BookReviewMapper">
  <resultMap id="BaseResultMap" type="com.peng.bms.model.BookReview">
    <id column="reviewId" jdbcType="INTEGER" property="reviewid" />
    <result column="bookId" jdbcType="INTEGER" property="bookid" />
    <result column="userId" jdbcType="INTEGER" property="userid" />
    <result column="rating" jdbcType="INTEGER" property="rating" />
    <result column="content" jdbcType="VARCHAR" property="content" />
    <result column="reviewTime" jdbcType="VARCHAR" property="reviewtime" />
  </resultMap>
  <resultMap id="DetailResultMap" type="com.peng.bms.model.BookReview" extends="BaseResultMap">
    <result column="userName" jdbcType="VARCHAR" property="username" />
    <result column="bookName" jdbcType="VARCHAR" property="bookname" />
  </resultMap>
  <insert id="insertSelective" parameterType="com.peng.bms.model.BookReview" useGeneratedKeys="true" keyProperty="reviewid">
    insert into book_review
    <trim prefix="(" suffix=")" suffixOverrides=",">
      <if test="bookid != null">bookId,</if>
      <if test="userid != null">userId,</if>
      <if test="rating != null">rating,</if>
      <if test="content != null">content,</if>
      <if test="reviewtime != null">reviewTime,</if>
    </trim>
    <trim prefix="values (" suffix=")" suffixOverrides=",">
      <if test="bookid != null">#{bookid},</if>
      <if test="userid != null">#{userid},</if>
      <if test="rating != null">#{rating},</if>
      <if test="content != null">#{content},</if>
      <if test="reviewtime != null">#{reviewtime},</if>
    </trim>
  </insert>
  <delete id="deleteByPrimaryKey" parameterType="java.lang.Integer">
    delete from book_review where reviewId = #{reviewid}
  </delete>
  <select id="selectByPrimaryKey" parameterType="java.lang.Integer" resultMap="DetailResultMap">
    select r.*, u.userName, b.bookName
    from book_review r
    left join user u on r.userId = u.userId
    left join book_info b on r.bookId = b.bookId
    where r.reviewId = #{reviewid}
  </select>
  <select id="selectCount" resultType="int">
    select count(*) from book_review
  </select>
  <select id="selectCountBySearch" resultType="int">
    select count(*) from book_review r
    left join user u on r.userId = u.userId
    left join book_info b on r.bookId = b.bookId
    <where>
      <if test="bookname != null and bookname != '' ">
        and b.bookName like concat('%',#{bookname},'%')
      </if>
      <if test="username != null and username != '' ">
        and u.userName like concat('%',#{username},'%')
      </if>
    </where>
  </select>
  <select id="selectBySearch" resultMap="DetailResultMap">
    select r.*, u.userName, b.bookName
    from book_review r
    left join user u on r.userId = u.userId
    left join book_info b on r.bookId = b.bookId
    <where>
      <if test="bookname != null and bookname != '' ">
        and b.bookName like concat('%',#{bookname},'%')
      </if>
      <if test="username != null and username != '' ">
        and u.userName like concat('%',#{username},'%')
      </if>
    </where>
    order by r.reviewTime desc limit #{begin}, #{size}
  </select>
  <select id="selectByBookId" resultMap="DetailResultMap">
    select r.*, u.userName, b.bookName
    from book_review r
    left join user u on r.userId = u.userId
    left join book_info b on r.bookId = b.bookId
    where r.bookId = #{bookid}
    order by r.reviewTime desc
  </select>
  <select id="selectAvgRatingByBookId" resultType="java.lang.Integer">
    select IFNULL(avg(rating), 0) from book_review where bookId = #{bookid}
  </select>
</mapper>
